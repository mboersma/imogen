# imogen foundation config (example)
#
# Copy to foundation.env and adjust, or just export these in your shell.
# Everything is parameterized so the dev galleries in a personal subscription
# can be swapped for the production galleries in the CNCF subscription.
#
# Defaults are applied by hack/setup-foundation.sh when a value is unset.

# Azure subscription to use. Defaults to the current `az account show` id.
# export IMOGEN_SUBSCRIPTION_ID=

# Region for the resource group and galleries.
export IMOGEN_LOCATION=westus3

# Resource group that holds the galleries.
export IMOGEN_RESOURCE_GROUP=imogen

# Gallery names. Azure gallery names allow letters, numbers, underscores and
# periods (no hyphens).
export IMOGEN_STAGING_GALLERY=imogen_staging
export IMOGEN_COMMUNITY_GALLERY=imogen_community

# Image definition identity. Definitions are named capi-<flavor>.
export IMOGEN_GALLERY_PUBLISHER=imogen
export IMOGEN_GALLERY_OFFER=imogen

# Flavors to create image definitions for (space separated).
export IMOGEN_FLAVORS="ubuntu-2404 ubuntu-2604 windows-2022-containerd windows-2025-containerd"

# Public community sharing on the community gallery. Leave false for dev; the
# production gallery in the CNCF subscription enables this. When true, also set
# the publisher fields below.
export IMOGEN_ENABLE_COMMUNITY=false
# export IMOGEN_COMMUNITY_PREFIX=imogen
# export IMOGEN_PUBLISHER_URI=https://github.com/mboersma/imogen
# export IMOGEN_PUBLISHER_EMAIL=Matt.Boersma@microsoft.com
# export IMOGEN_PUBLISHER_EULA=https://github.com/mboersma/imogen/blob/main/LICENSE

# --- image build (temporary standalone container build) ---

# image-builder released container that bundles az CLI, Packer and the Azure
# plugin. ENTRYPOINT is `make`; the build target is passed as the command.
export IMOGEN_BUILDER_IMAGE=registry.k8s.io/scl-image-builder/cluster-node-image-builder-amd64:v0.1.52

# User-assigned managed identity the build authenticates with. Create it with
# hack/setup-build-identity.sh, which prints the client and resource ids.
export IMOGEN_BUILDER_IDENTITY=imogen-builder
# export IMOGEN_BUILDER_CLIENT_ID=
# export IMOGEN_BUILDER_IDENTITY_ID=

# --- agent (kagent + Azure OpenAI) ---

# Azure OpenAI account and model deployment the agent uses. Create them with
# hack/setup-openai.sh. The account is Entra-only (no API keys) per policy.
export IMOGEN_OPENAI_LOCATION=eastus2
# export IMOGEN_OPENAI_ACCOUNT=imogen-openai-<sub-prefix>
export IMOGEN_OPENAI_DEPLOYMENT=gpt-4.1-mini
export IMOGEN_OPENAI_MODEL=gpt-4.1-mini
export IMOGEN_OPENAI_MODEL_VERSION=2025-04-14

# --- builder cluster (CAPZ) ---

# AKS management cluster + CAPZ. Created by hack/setup-mgmt-cluster.sh. The mgmt
# region is independent of the galleries; eastus2 has AKS capacity.
export IMOGEN_MGMT_CLUSTER=imogen-mgmt
export IMOGEN_MGMT_LOCATION=eastus2
# User-assigned identity CAPZ uses, federated to the controller service accounts.
export IMOGEN_CAPZ_IDENTITY=imogen-capz

# Builder workload cluster with a VMSS MachinePool. Created by
# hack/setup-builder-cluster.sh, scaled by hack/scale-builder.sh.
export IMOGEN_BUILDER_CLUSTER=imogen-builder
export IMOGEN_BUILDER_K8S_VERSION=v1.34.8
export IMOGEN_BUILDER_NODE_SIZE=Standard_D2s_v3
export IMOGEN_BUILDER_WORKERS=1
# Region the builder cluster runs in. Validation replicates the staging image
# here so a node can boot from it. Defaults to the mgmt region.
export IMOGEN_BUILDER_LOCATION=eastus2
